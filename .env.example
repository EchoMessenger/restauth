# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=tinode
KEYCLOAK_CLIENT_ID=tinode-server
KEYCLOAK_CLIENT_SECRET=
# Если client public — оставить пустым

# Приложение
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# SQLite
DB_PATH=tinode_keycloak.db

# Restricted tag namespaces
RESTRICTED_TAG_NS=rest,email,uname
# Regex для валидации логинов (будет base64-кодироваться)
LOGIN_VALIDATION_RE=^[a-zA-Z0-9_.\-@]{3,64}$